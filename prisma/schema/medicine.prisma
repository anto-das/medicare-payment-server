model Medicine {
  medicine_id     String         @id @default(uuid())
  medicine_name   String         @db.VarChar(150)
  manufacturer    String
  medi_img        String
  category_name   String         @default("ANTIBIOTICS")
  seller_id       String
  price           Decimal        @db.Decimal(10, 0)
  stock_quantity  Int            @default(0)
  createdAt       DateTime       @default(now())
  generic_name    String         @default("") @db.VarChar(150)
  description     String         @default("")
  unit_type       String         @default("TABLET") @db.VarChar(50)
  strength        String         @default("")
  approval_status ApprovalStatus @default(PENDING)
  Cart            Cart[]

  orderItems            Order_item[]
  categories            Categories?  @relation(fields: [categoriesCategory_id], references: [category_id])
  categoriesCategory_id String?
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
