model Orders {
    order_id       String       @id @default(uuid())
    customer_email String
    customer_name  String       @default("")
    user           User         @relation(fields: [customer_email], references: [email])
    seller_id      String
    status         Status       @default(PENDING)
    total_bill     Decimal      @db.Decimal(10, 0)
    payment_status String       @default("UNPAID")
    order_date     DateTime     @default(now()) @db.Timestamp()
    createdAt      DateTime     @default(now())
    orderItems     Order_item[]
    reviews        Reviews[]
    payment        Payment[]
}

enum Status {
    PENDING
    PROCESSING
    SHIPPED
    DELIVERED
    CANCELLED
}

enum PaymentStatus {
    PAID
    UNPAID
}
