model Cart {
  cart_id       String    @unique @default(uuid())
  medicine_name String    @db.VarChar(150)
  generic_name  String    @default("strip") @db.VarChar(150)
  manufacturer  String
  medi_img      String
  price         Decimal   @db.Decimal(10, 0)
  category_name String    @default("ANTIBIOTICS")
  medicine_id   String?
  user_id       String?
  guest_id      String?
  quantity      Int       @default(1)
  medicine      Medicine? @relation(fields: [medicine_id], references: [medicine_id])
  user          User?     @relation(fields: [user_id], references: [id])
}
